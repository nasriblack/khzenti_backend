// Khzanti - Prisma Schema
// Database: PostgreSQL
// Run: npx prisma generate && npx prisma db push

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// USER MODEL
// ============================================

model Whitelist {
  id        String   @id @default(uuid())
  email     String   @unique
  ipAddress String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ipAddress])
  @@index([email])
  @@map("whitelist")
}

model User {
  id       String  @id @default(cuid())
  email    String  @unique
  password String // Hashed with bcrypt
  name     String?
  age      Int?
  location String? // e.g., "Tunis", "Sfax"

  maxWardrobeItems Int @default(7)

  maxOutfitGenerations  Int @default(5)
  outfitGenerationsUsed Int @default(0)

  // Style preferences (array of strings)
  stylePreferences String[] // ["casual", "elegant", "sport", etc.]

  // Account status
  emailVerified DateTime?
  isActive      Boolean   @default(true)
  isPremium     Boolean   @default(false)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  wardrobeItems     WardrobeItem[]
  outfits           Outfit[]
  suggestionHistory SuggestionHistory[]
  // notifications     Notification[]

  @@index([email])
  @@map("users")
}

// ============================================
// WARDROBE ITEM MODEL
// ============================================

model WardrobeItem {
  id     String @id @default(cuid())
  userId String

  // Item details
  imageUrl String // Cloudflare R2 or Supabase Storage URL
  category Category
  colors   String[] // ["#000000", "#FFFFFF", "#3B82F6"]
  season   Season   @default(ALL)
  brand    String?
  notes    String?

  // Style tags (AI-detected + user-added)
  styleTags String[] // ["casual", "formal", "vintage", etc.]

  // Usage tracking
  lastWornDate DateTime?
  timesWorn    Int       @default(0)
  isFavorite   Boolean   @default(false)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  outfits OutfitItem[]

  @@index([userId])
  @@index([category])
  @@index([userId, category])
  @@map("wardrobe_items")
}

enum Category {
  TOPS // قمصان
  BOTTOMS // بناطيل
  SHOES // أحذية
  JACKETS // جواكت
  ACCESSORIES // إكسسوارات
}

enum Season {
  SUMMER // صيف
  WINTER // شتاء
  SPRING // ربيع
  FALL // خريف
  ALL // كل المواسم
}

// ============================================
// OUTFIT MODEL
// ============================================

model Outfit {
  id     String @id @default(cuid())
  userId String

  // Outfit metadata
  name     String? // Optional user-given name
  style    Style // casual, elegant, sport, etc.
  occasion Occasion @default(CASUAL)

  // AI-generated explanation
  aiExplanation String? // "لبسة كاجوال مريحة تناسب الطقس..."

  // Outfit status
  isDailySuggestion Boolean   @default(false)
  isSaved           Boolean   @default(false)
  wornDate          DateTime? // When user actually wore it

  // User feedback
  userFeedback Feedback?
  rating       Int?      @default(0) // 1-5 stars

  // Weather context (when generated)
  weatherTemp      Float?
  weatherCondition String? // "sunny", "rainy", "cloudy"

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user    User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  items   OutfitItem[]
  history SuggestionHistory[]

  @@index([userId])
  @@index([userId, isSaved])
  @@index([userId, isDailySuggestion])
  @@index([wornDate])
  @@map("outfits")
}

// Junction table for many-to-many relationship
model OutfitItem {
  id       String @id @default(cuid())
  outfitId String
  itemId   String

  // Position in outfit (for ordering)
  position Int @default(0)

  outfit Outfit       @relation(fields: [outfitId], references: [id], onDelete: Cascade)
  item   WardrobeItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([outfitId, itemId])
  @@index([outfitId])
  @@index([itemId])
  @@map("outfit_items")
}

enum Style {
  CASUAL // كاجوال
  ELEGANT // إليغان
  SPORT // سبور
  STREETWEAR // ستريت وير
  VINTAGE // فينتاج
  MINIMAL // مينيمال
}

enum Occasion {
  WORK // شغل
  CASUAL // خرجة عادية
  DATE // موعد
  WEDDING // عرس
  SPORT // رياضة
  PARTY // حفلة
  FORMAL // رسمي
}

enum Feedback {
  LIKE
  DISLIKE
  NEUTRAL
}

// ============================================
// SUGGESTION HISTORY MODEL
// ============================================

model SuggestionHistory {
  id       String @id @default(cuid())
  userId   String
  outfitId String

  // Suggestion context
  suggestionDate DateTime @default(now())
  wasAccepted    Boolean  @default(false)
  wasWorn        Boolean  @default(false)

  // User interaction
  viewedAt    DateTime?
  respondedAt DateTime? // When user gave feedback

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  outfit Outfit @relation(fields: [outfitId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([suggestionDate])
  @@index([userId, suggestionDate])
  @@map("suggestion_history")
}

